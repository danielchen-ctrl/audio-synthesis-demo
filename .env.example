# ============================================
# 音频语料生成平台 — 环境变量示例
# 复制为 .env 后填入真实值
# ============================================

# --- 应用 ---
APP_ENV=development                # development / production
APP_NAME=audio-platform
APP_PORT=8000
LOG_LEVEL=INFO

# --- 安全 ---
# 生成方法: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=please-change-me-in-prod-use-secrets-token_urlsafe-32
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# --- Google SSO（可选，留空则禁用）---
# 在 https://console.cloud.google.com/apis/credentials 创建 OAuth Client ID（Web application）
# 添加 http://localhost:5173 到 Authorized JavaScript origins
GOOGLE_CLIENT_ID=
GOOGLE_ALLOWED_DOMAIN=plaud.ai

# --- MySQL ---
# 本地开发(经 bastion SSH 隧道到 RDS): MYSQL_HOST=127.0.0.1, MYSQL_PORT=13306
#   ssh -fN -L 13306:<rds-endpoint>:3306 ubuntu@<你的跳板机>
# 线上(VPC 内直连): MYSQL_HOST=<rds-endpoint>, MYSQL_PORT=3306
# 本地起 docker-compose.dev.yml: MYSQL_HOST=localhost, MYSQL_PORT=3306
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=audio_platform
MYSQL_USER=app
MYSQL_PASSWORD=changeme

# --- Redis ---
# 本地开发: redis://localhost:6379/0；容器内: redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0

# --- MinIO ---
# 本地开发: localhost:9000；容器内: minio:9000
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=audio-platform
MINIO_USE_SSL=false
MINIO_PUBLIC_ENDPOINT=http://localhost:9000   # 浏览器可访问的地址（用于签名 URL）

# --- LLM ---
# 当前选型: DeepSeek；切换其他 provider 只需改 LLM_PROVIDER 和对应 API key/base_url
LLM_PROVIDER=deepseek                 # deepseek / openai / anthropic
LLM_API_KEY=sk-please-set-your-deepseek-key
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_TIMEOUT_SEC=60
LLM_MAX_TOKENS=4096

# --- CosyVoice TTS ---
COSYVOICE_BASE_URL=http://cosyvoice.internal:8000
COSYVOICE_MODEL=cosyvoice-v3
COSYVOICE_TIMEOUT_SEC=120
COSYVOICE_MAX_RETRIES=2
COSYVOICE_MAX_CONCURRENCY=1

# --- 部署端口（仅 docker-compose.prod.yml 用，--env-file 注入做插值）---
# 宿主 80 被占时改这里（如共享服务器）。访问地址即 http://<服务器IP>:<HTTP_PORT>
HTTP_PORT=80
MINIO_API_PORT=9000        # MinIO S3 API 暴露的宿主端口（浏览器签名 URL 直连）
MINIO_CONSOLE_PORT=9001    # MinIO 控制台

# --- 业务限制 ---
MAX_UPLOAD_SIZE_MB=500
MAX_CONCURRENT_TASKS_PER_USER=3
MAX_PLATFORM_CONCURRENT_TASKS=50

# --- CORS（开发用，生产由 nginx 处理）---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
